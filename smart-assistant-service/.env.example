# --- Servicio Smart Assistant (VPS) ---

# Token de tu SUSCRIPCIÓN de Claude. Genéralo en tu Mac con:  claude setup-token
# Dura 1 año, no se autorrenueva. NO lo compartas.
CLAUDE_CODE_OAUTH_TOKEN=

# Cadena de conexión Postgres de Supabase (idealmente un usuario de SOLO LECTURA).
# La encuentras en Supabase → Project Settings → Database → Connection string (URI).
# Ej: postgresql://USER:PASSWORD@HOST:5432/postgres
SUPABASE_DB_URL=

# Secreto compartido que la Smart App envía como Bearer. Inventa uno largo y aleatorio.
# Debe coincidir con ASSISTANT_API_SECRET en Vercel.
ASSISTANT_SHARED_SECRET=

# Modelo (opcional). Por defecto Sonnet 4.6.
ASSISTANT_MODEL=claude-sonnet-4-6

# Puerto interno (opcional)
PORT=8645
